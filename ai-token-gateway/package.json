    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.1",
    "fast-check": "^4.1.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/uuid": "^10.0.0",
    "@types/node": "^22.15.0"

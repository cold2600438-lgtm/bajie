{
  "name": "ai-token-gateway",
  "version": "1.0.0",
  "description": "AI Token sharing gateway - proxy service for sharing LLM API keys",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
